#include <stdio.h>

int main()  {
    int i, j, matriz[4][4] = {0}, maior = 0, linha[4] = {0}, coluna[4] = {0};
    
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4; j++) {
            printf("ME INFORME O NUMERO DA LINHA %d COLUNA %d: ", i + 1, j + 1);
            scanf("%d", &matriz[i][j]);
            linha[i] += matriz[i][j];
            coluna[j] += matriz[i][j];
        }
    }
    
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4; j++) {
            printf("%d\t", matriz[i][j]);
        }
        printf("\n");
    }
    
    for(i = 0; i < 4; i++) {
            printf("LINHA %d: %d\n", i + 1, linha[i]);
            printf("COLUNA %d: %d\n", j + 1, coluna[i]);

    }

    
    return 0;
}
