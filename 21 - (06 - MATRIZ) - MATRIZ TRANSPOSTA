#include <stdio.h>

int main()  {
    int i, j, matriz[3][2] = {0}, matriz2[2][3] = {0}, maior = 0, linha[4] = {0}, coluna[4] = {0};
    
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 2; j++) {
            printf("ME INFORME O NUMERO DA LINHA %d COLUNA %d: ", i + 1, j + 1);
            scanf("%d", &matriz[i][j]);
            matriz2[j][i] = matriz[i][j];
        }
    }
    
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 2; j++) {
            printf("%d\t", matriz[i][j]);
        }
        printf("\n");
    }
    printf("\n\n");
    
    for(i = 0; i < 2; i++) {
        for(j = 0; j < 3; j++) {
            printf("%d\t", matriz2[i][j]);
        }
        printf("\n");
    }
    
    return 0;
}
