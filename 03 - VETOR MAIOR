#include <stdio.h>

int main()  {
    int array[10] = {0}, i, maior = 0;
    
    for(i = 0; i < 10; i++) {
        
        printf("\nME INFORME UM NUMERO: ");
        scanf("%d", &array[i]);
        
        
        if(array[i] >= maior) {
            
            maior = array[i];
        }
        
    }
    
    printf("\nVALOR MAIOR E: %d ",maior);
    
    return 0;
}
