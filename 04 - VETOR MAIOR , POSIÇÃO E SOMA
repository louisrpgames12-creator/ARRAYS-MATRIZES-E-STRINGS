#include <stdio.h>

int main()  {
    int array[10] = {0}, i, posicao, maior = 0, acumulado = 0;
    
    for(i = 0; i < 10; i++) {
        
        printf("\nME INFORME UM NUMERO: ");
        scanf("%d", &array[i]);
        
        acumulado += array[i];
        
        if(array[i] >= maior) {
            
            maior = array[i];
            posicao = i + 1;
        }
        
    }
    
    printf("A SOMA E: %d\nVALOR MAIOR E: %d NA POSICAO: %d",acumulado, maior, posicao);
    
    return 0;
}
