#include <stdio.h>

int paresarray(int array[], int tamanho) {
    
    int i, pares = 0;
    
    for(i = 0; i < tamanho; i++) {
        
        if(array[i] % 2 == 0)
            pares++;
        
    }
    
    return pares;
    
}

int main()  {
    int array[10] = {0}, i, tamanho = 10;
    
    for(i = 0; i < 10; i++) {
        
        printf("ME INFORME UM NUMERO: ");
        scanf("%d", &array[i]);
        
    }
    
    printf("%d", paresarray(array, tamanho));
    

    return 0;
}
