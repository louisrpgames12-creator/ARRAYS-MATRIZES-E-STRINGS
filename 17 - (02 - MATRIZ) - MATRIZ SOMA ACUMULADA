#include <stdio.h>

int main()  {
    float matriz[4][3] = {0}, soma = 0;
    int i, j;
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 3; j++) {
            printf("ME INFORME O NUMERO DA LINHA %d COLUNA %d: ", i + 1, j + 1);
            scanf("%f", &matriz[i][j]);
        }
    }
    
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 3; j++) {
            printf("%.2f\t", matriz[i][j]);
            soma += matriz[i][j];
        }
        printf("\n");
    }
    
    printf("\nA SOMA: %.2f", soma);
    return 0;
}
