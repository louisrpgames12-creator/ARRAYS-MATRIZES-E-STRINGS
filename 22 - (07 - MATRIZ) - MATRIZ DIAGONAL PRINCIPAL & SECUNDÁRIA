#include <stdio.h>

int main()  {
    int i, j, matriz[4][4] = {0}, diagonalprincipal[4] = {0}, diagonalsecundaria[4] = {0};
    
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4; j++) {
            printf("ME INFORME O NUMERO DA LINHA %d COLUNA %d: ", i + 1, j + 1);
            scanf("%d", &matriz[i][j]);
            if(i == j)
            diagonalprincipal[i] = matriz[i][j];
            if(i + j == 3)
            diagonalsecundaria[i] = matriz[i][j];
        }
    }
    
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4; j++) {
            printf("%d\t", matriz[i][j]);
        }
        printf("\n");
    }
    printf("\n\n");
    
    for(i = 0; i < 4; i++) {
        printf("%d ", diagonalprincipal[i]);
    }
    printf("\n");
    
    for(i = 0; i < 4; i++) {
        printf("%d ", diagonalsecundaria[i]);
    }
    
    return 0;
}
