#include <stdio.h>

int main() {
    int A[2][3], B[3][2], C[2][2];
    int i, j, k;

    for(i = 0; i < 2; i++) {
        for(j = 0; j < 3; j++) {
            printf("Matriz A Linha %d, Coluna %d: ", i + 1, j + 1);
            scanf("%d", &A[i][j]);
        }
    }

    printf("\n");

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 2; j++) {
            printf("Matriz B Linha %d, Coluna %d: ", i + 1, j + 1);
            scanf("%d", &B[i][j]);
        }
    }

    for(i = 0; i < 2; i++) {
        for(j = 0; j < 2; j++) {
            C[i][j] = 0;
            
            for(k = 0; k < 3; k++) {
                C[i][j] = C[i][j] + (A[i][k] * B[k][j]);
            }
        }
    }

    for(i = 0; i < 2; i++) {
        for(j = 0; j < 2; j++) {
            printf("%d\t", C[i][j]);
        }
        printf("\n"); 
    }

    return 0;
}
