#include <stdio.h>

int main()  {
    int i, j, matriz[3][2] = {0};
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 2; j++) {
            printf("ME INFORME O NUMERO DA LINHA %d COLUNA %d: ", i + 1, j + 1);
            scanf("%d", &matriz[i][j]);
        }
    }
    
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 2; j++) {
            printf("%d\t", matriz[i][j]);
        }
        printf("\n");
    }
    return 0;
}
