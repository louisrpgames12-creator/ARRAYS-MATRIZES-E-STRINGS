#include <stdio.h>

int main()  {
    int i;
    int array[6] = {0};
    
    for(i = 0; i < 6; i++) {
        
        printf("\nME INFORME UM NUMERO: ");
        scanf("%d", &array[i]);
        
    }
    
    printf("A ORDEM DECRESCENTE E: ");
    
    for(i = 5; i >= 0; i--) {
        
        printf("\n%d", array[i]);
        
    }
    
    return 0;
}
