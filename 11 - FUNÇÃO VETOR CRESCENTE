        for(j = 0; j < i; j++) {
            if(array[i] < array[j]) {
                aux = array[j];
                array[j] = array[i];
               array[i] = aux;
            }
        }
    }
    
    for(i = 0; i < tamanho; i++) {
        
    printf("%d", array[i]);
    
    }
}

int main() {
    int tamanho, i;
    
    printf("ME INFORME O TAMANHO DE UM VETOR: ");
    scanf("%d", &tamanho);
    
